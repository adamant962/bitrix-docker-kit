# =============================================================================
# Bitrix Docker — универсальная сборка для локальной разработки
# Скопируйте этот файл в .env и отредактируйте под свой проект
# =============================================================================

# --- Проект ----------------------------------------------------------------
COMPOSE_PROJECT_NAME=vegaproject
PROJECT_DOMAIN=vegaproject.loc
# Рекомендуемый вариант для новых проектов:
# PROJECT_ROOT=./www
#
# Для старых проектов, где bitrix/local/upload лежат в корне:
# PROJECT_ROOT=.
PROJECT_ROOT=./www
DOCUMENT_ROOT=/var/www/html

# --- Порты ----------------------------------------------------------------
HTTP_PORT=80
DB_PORT_EXTERNAL=3307
ADMINER_PORT=8080

# --- HTTPS ---------------------------------------------------------------
# HTTPS включается через docker-compose.https.yml
# Для локальной разработки безопаснее 8443.
# Порт 443 часто занят Windows/IIS/OpenServer/другим Docker-проектом.
# Если 443 свободен и нужен URL без порта, можно поставить HTTPS_PORT=443.
HTTPS_PORT=8443

# Обычно HTTPS_DOMAIN должен совпадать с PROJECT_DOMAIN.
HTTPS_DOMAIN=vegaproject.loc

# --- PHP ------------------------------------------------------------------
# Доступные образы:
#   php:8.0-fpm-bullseye
#   php:8.1-fpm-bullseye
#   php:8.2-fpm-bookworm
#   php:8.3-fpm-bookworm
#   php:8.4-fpm-bookworm
PHP_IMAGE=php:8.2-fpm-bookworm
PHP_TAG=8.2

# --- PHP-настройки (фиксированные в docker/php/php.ini) --------------------
PHP_MEMORY_LIMIT=512M
PHP_UPLOAD_MAX_FILESIZE=100M
PHP_POST_MAX_SIZE=100M
PHP_MAX_EXECUTION_TIME=120
PHP_MAX_INPUT_VARS=10000
PHP_TIMEZONE=Europe/Moscow

# --- База данных ----------------------------------------------------------
# Доступные образы:
#   mysql:5.7, mysql:8.0, mysql:8.4
#   mariadb:10.6, mariadb:10.11, mariadb:11.4
DB_IMAGE=mysql:8.0
DB_HOST=db
DB_PORT=3306
DB_DATABASE=vegaproject
DB_USER=bitrix
DB_PASSWORD=bitrix_password
DB_ROOT_PASSWORD=root_password

DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci
DB_SQL_MODE=

# --- Xdebug ---------------------------------------------------------------
# 0 — выключен, 1 — включён (требуется docker compose build после изменения)
ENABLE_XDEBUG=0

# --- Профили сервисов -----------------------------------------------------
# Запуск с профилями:
#   docker compose --profile cron up -d       # только cron
#   docker compose --profile tools up -d      # adminer (+ cron, если указан)
#   docker compose --profile cron --profile tools up -d
#
# cron — Bitrix-агенты (запускаются каждые 60 секунд)
# tools — adminer для управления БД через веб-интерфейс

# --- Права на хосте -------------------------------------------------------
# Для Linux/WSL: укажите uid и gid вашего пользователя (id -u, id -g)
HOST_UID=1000
HOST_GID=1000

# --- Архитектура (macOS Apple Silicon) ------------------------------------
# Обычно оставляйте пустым.
# Для старых amd64-образов используйте docker-compose.platform-amd64.yml:
#   docker compose -f docker-compose.yml -f docker-compose.platform-amd64.yml up -d
DOCKER_PLATFORM=
