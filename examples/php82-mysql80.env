# =============================================================================
# Bitrix Docker Kit — PHP 8.2 + MySQL 8.0
# Обязательно поменяйте значения под ваш проект
# =============================================================================

COMPOSE_PROJECT_NAME=bitrix_php82_mysql80
PROJECT_DOMAIN=php82-mysql80.loc
PROJECT_ROOT=.

HTTP_PORT=8081
HTTPS_PORT=8441
DB_PORT_EXTERNAL=3307
ADMINER_PORT=8091
HTTPS_DOMAIN=php82-mysql80.loc

PHP_IMAGE=php:8.2-fpm-bookworm
PHP_TAG=8.2

DB_IMAGE=mysql:8.0
DB_DATABASE=bitrix_php82_mysql80
DB_USER=bitrix
DB_PASSWORD=bitrix_password
DB_ROOT_PASSWORD=root_password

DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci
DB_SQL_MODE=

ENABLE_XDEBUG=0
HOST_UID=1000
HOST_GID=1000
