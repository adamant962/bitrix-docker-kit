# =============================================================================
# Bitrix Docker Kit — PHP 8.0 + MySQL 5.7 (legacy)
# Обязательно поменяйте значения под ваш проект
# =============================================================================

COMPOSE_PROJECT_NAME=bitrix_php80_mysql57
PROJECT_DOMAIN=php80-mysql57.loc
PROJECT_ROOT=.

HTTP_PORT=8084
HTTPS_PORT=8444
DB_PORT_EXTERNAL=3310
ADMINER_PORT=8094
HTTPS_DOMAIN=php80-mysql57.loc

PHP_IMAGE=php:8.0-fpm-bullseye
PHP_TAG=8.0

DB_IMAGE=mysql:5.7
DB_DATABASE=bitrix_php80_mysql57
DB_USER=bitrix
DB_PASSWORD=bitrix_password
DB_ROOT_PASSWORD=root_password

DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci
DB_SQL_MODE=

ENABLE_XDEBUG=0
HOST_UID=1000
HOST_GID=1000
