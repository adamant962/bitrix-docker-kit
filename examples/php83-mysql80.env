# =============================================================================
# Bitrix Docker Kit — PHP 8.3 + MySQL 8.0
# Обязательно поменяйте значения под ваш проект
# =============================================================================

COMPOSE_PROJECT_NAME=bitrix_php83_mysql80
PROJECT_DOMAIN=php83-mysql80.loc
PROJECT_ROOT=./www
TZ=Europe/Moscow

HTTP_PORT=8083
HTTPS_PORT=8443
DB_PORT_EXTERNAL=3309
ADMINER_PORT=8093
HTTPS_DOMAIN=php83-mysql80.loc
MAILPIT_WEB_PORT=8028

PHP_IMAGE=php:8.3-fpm-bookworm
PHP_TAG=8.3

DB_IMAGE=mysql:8.0
DB_DATABASE=bitrix_php83_mysql80
DB_USER=bitrix
DB_PASSWORD=bitrix_password
DB_ROOT_PASSWORD=root_password

DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci
DB_SQL_MODE=
DB_TIMEZONE=+03:00

ENABLE_XDEBUG=0
HOST_UID=1000
HOST_GID=1000
