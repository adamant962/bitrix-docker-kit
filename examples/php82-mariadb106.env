# =============================================================================
# Bitrix Docker Kit — PHP 8.2 + MariaDB 10.6
# Обязательно поменяйте значения под ваш проект
# =============================================================================

COMPOSE_PROJECT_NAME=bitrix_php82_mariadb106
PROJECT_DOMAIN=php82-mariadb106.loc
PROJECT_ROOT=./www

HTTP_PORT=8085
HTTPS_PORT=8445
DB_PORT_EXTERNAL=3311
ADMINER_PORT=8095
HTTPS_DOMAIN=php82-mariadb106.loc

PHP_IMAGE=php:8.2-fpm-bookworm
PHP_TAG=8.2

DB_IMAGE=mariadb:10.6
DB_DATABASE=bitrix_php82_mariadb106
DB_USER=bitrix
DB_PASSWORD=bitrix_password
DB_ROOT_PASSWORD=root_password

DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci
DB_SQL_MODE=

ENABLE_XDEBUG=0
HOST_UID=1000
HOST_GID=1000
