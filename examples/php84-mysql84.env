# =============================================================================
# Bitrix Docker Kit — PHP 8.4 + MySQL 8.4
# Обязательно поменяйте значения под ваш проект
# =============================================================================

COMPOSE_PROJECT_NAME=bitrix_php84_mysql84
PROJECT_DOMAIN=php84-mysql84.loc
PROJECT_ROOT=.

HTTP_PORT=8082
HTTPS_PORT=8442
DB_PORT_EXTERNAL=3308
ADMINER_PORT=8092
HTTPS_DOMAIN=php84-mysql84.loc

PHP_IMAGE=php:8.4-fpm-bookworm
PHP_TAG=8.4

DB_IMAGE=mysql:8.4
DB_DATABASE=bitrix_php84_mysql84
DB_USER=bitrix
DB_PASSWORD=bitrix_password
DB_ROOT_PASSWORD=root_password

DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci
DB_SQL_MODE=

ENABLE_XDEBUG=0
HOST_UID=1000
HOST_GID=1000
